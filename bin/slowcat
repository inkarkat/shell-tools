#!/bin/bash
set -o pipefail

export DURATIONWITHADJUSTMENTTOSECONDS_ACCEPT_FRACTIONAL=t DURATIONTOSECONDS_ACCEPT_FRACTIONAL=t

printShortUsage()
{
    # Note: short followed by long option; if the user knows the short one, she can
    # skim the long one.
    printf 'Usage: %q %s\n' "$(basename "$1")" "[-i|--initial TIMESPAN] [-l|--line TIMESPAN[ADJUSTMENT]] [-c|--char TIMESPAN[ADJUSTMENT]] FILE [...] [-?|-h|--help]"
    echo
    printf 'Usage: %q %s\n' "$(basename "$1")" "[-i|--initial TIMESPAN] [-L|--line-total|-C|--char-total TIMESPAN] FILE [...] [-?|-h|--help]"
    echo
    printf 'Usage: cat FILE [...] | %q %s\n' "$(basename "$1")" '[...]'
}
printUsage()
{
    # This is the short help when launched with no or incorrect arguments.
    # It is printed to stderr to avoid accidental processing.
    printShortUsage "$1" >&2
    printf >&2 '\nTry %q --help for more information.\n' "$(basename "$1")"
}
printLongUsage()
{
    # This is the long "man page" when launched with the help argument.
    # It is printed to stdout to allow paging with 'more'.
    cat <<HELPDESCRIPTION
Print file contents on standard output with delay(s).
HELPDESCRIPTION
    echo
    printShortUsage "$1"
    echo
    local -r timespanFormat="$(durationToSeconds --get-short-usage format 2>/dev/null || echo TIMESPAN)"
    cat <<HELPTEXT
    --initial|-i $timespanFormat
			Delay before doing any output at all.
HELPTEXT
	durationWithAdjustmentToSeconds --get-long-usage '--line|-l' 'Delay after each complete line (line); this also
			considers inner carriage returns.'
	durationWithAdjustmentToSeconds --get-long-usage '--char|-c' 'Delay after each individual character (char) other
			than newlines.'
    cat <<HELPTEXT
    --line-total|-L $timespanFormat
			Delay individual lines so that the total output time of
			all FILE(s) is about TIMESPAN.
    --char-total|-C $timespanFormat
			Delay individual characters so that the total output
			time of all FILE(s) is about TIMESPAN.
HELPTEXT
}

initialDelay=
lineDelay=
charDelay=
lineDelayAdjustment=
charDelayAdjustment=
total=
totaller=
totalTargetDelay=
consumer=
linePrinter='printf %s'
while [ $# -ne 0 ]
do
    case "$1" in
	--help|-h|-\?)	shift; printLongUsage "$0"; exit 0;;
	--initial|-i)	shift; initialDelay=$(durationToSeconds -- "${1:?}") || { printf >&2 'ERROR: Illegal TIMESPAN: %s\n' "$1"; exit 2; }; shift;;

	--line|-l)	shift; < <(durationWithAdjustmentToSeconds --no-adjustment "${1:?}") IFS=$'\t' read -r lineDelay lineDelayAdjustment || exit 2; shift; consumer=lineDelay;;
	--char|-c)	shift; < <(durationWithAdjustmentToSeconds --no-adjustment "${1:?}") IFS=$'\t' read -r charDelay charDelayAdjustment || exit 2; shift; linePrinter=charDelay;;
	--line-total|-L)
			shift; total=$(DURATIONTOSECONDS_ACCEPT_FRACTIONAL=t durationToSeconds -- "${1:?}") || { printf >&2 'ERROR: Illegal TIMESPAN: %s\n' "$1"; exit 2; }; shift; totaller=-l; totalTargetDelay=lineDelay; consumer=lineDelay;;
	--char-total|-C)
			shift; total=$(DURATIONTOSECONDS_ACCEPT_FRACTIONAL=t durationToSeconds -- "${1:?}") || { printf >&2 'ERROR: Illegal TIMESPAN: %s\n' "$1"; exit 2; }; shift; totaller=-c; totalTargetDelay=charDelay; linePrinter=charDelay;;
	--)		shift; break;;
	-*)		{ echo "ERROR: Unknown option \"$1\"!"; echo; printUsage "$0"; } >&2; exit 2;;
	*)		break;;
    esac
done
if [ -n "$total" ]; then
    if [ -n "$charDelay" -o -n "$lineDelay" ]; then
	echo 'ERROR: Cannot combine --line-total or --char-total with --line or --char.'
	echo
	printUsage "$0"
	exit 2
    elif [ $# -eq 0 ]; then
	echo 'ERROR: --line-total and --char-total need FILE(s) passed; cannot read from standard input.'
	echo
	printUsage "$0"
	exit 2
    fi >&2

    requiredSteps=$(cat -- "$@" | wc $totaller) || exit $?
    delay=$(bc <<<"scale=10; $total / $requiredSteps") || exit 3
    eval "$totalTargetDelay=$delay"
fi
[ -n "$charDelay" -a -z "$consumer" ] && consumer=lineReader


typeset -a ADJUSTER=()
adjustInto()
{
    local -n resultRef="${1:?}"; shift
    local input="${1:?}"; shift

    [ ${#ADJUSTER[@]} -gt 0 ] \
	|| coproc ADJUSTER { durationWithAdjustmentToSeconds; } # Start a coproc to adjust individual timespans and manage expiration; this is much more efficient than starting a new process for each timespan.

    printf '%s\n' "$input" >&"${ADJUSTER[1]}"
    IFS=$'\n' read -r -u "${ADJUSTER[0]}" resultRef \
    || { printf >&2 'ASSERT: Adjustment succeeds: %s\n' "$input"; exit 3; }
    case ",${DEBUG:-}," in *,slowcat:adjuster,*) printf >&2 '%sslowcat (adjuster): %s -> %s\n' "$PS5" "$input" "$resultRef";; esac
}
adjustLineDelay()
{
    [ -n "$lineDelayAdjustment" ] || return 1
    adjustInto lineDelay "${lineDelay}${lineDelayAdjustment}"
    [ "$lineDelay" != 0 ] || lineDelayAdjustment=''    # Optimization: Once the timespan has been reduced to zero, it's not gonna increase again, so we can stop adjusting.
}
adjustCharDelay()
{
    [ -n "$charDelayAdjustment" ] || return 1
    adjustInto charDelay "${charDelay}${charDelayAdjustment}"
    [ "$charDelay" != 0 ] || charDelayAdjustment=''    # Optimization: Once the timespan has been reduced to zero, it's not gonna increase again, so we can stop adjusting.
}


lineReader()
{
    isEOL=t
    while IFS=$'\n' read -r line || { isEOL=; [ -n "$line" ]; }
    do
	$linePrinter "$line"

	if [ "$isEOL" ]; then
	    printf '\n'
	fi
    done
}

lineDelay()
{
    isEOL=t
    while IFS=$'\r' read -ra lines || { isEOL=; [ ${#lines[@]} -gt 0 ]; }
    do
	let cnt=0
	for line in "${lines[@]}"
	do
	    let cnt+=1

	    # Return to the first column before printing a subsequent internal line
	    # fragment.
	    [ $cnt -gt 1 ] && printf '\r'

	    $linePrinter "$line"

	    # Conclude the last line fragment with a newline.
	    if [ $cnt -eq ${#lines[@]} ]; then
		if [ "$isEOL" ]; then
		    printf '\n'
		else
		    # Don't delay when there's no trailing newline.
		    continue
		fi
	    fi

	    sleep "$lineDelay"
	    adjustLineDelay
	done
    done
}

charDelay()
{
    local line="$1"; shift
    local i
    for ((i = 0; i < ${#line}; i++))
    do
	printf %s "${line:i:1}"

	sleep "$charDelay"
	adjustCharDelay
    done
}


[ -z "$initialDelay" ] || sleep "$initialDelay"
eval cat -- '"$@"' \
    "${consumer:+|} $consumer"; status=$?

[ ${#ADJUSTER[@]} -eq 0 ] || exec {ADJUSTER[1]}>&- {ADJUSTER[0]}<&-; ADJUSTER=()
    exit $status
