#!/bin/bash
shopt -qs extglob

export DURATIONTOSECONDS_ACCEPT_SIGN=t

readonly compareArgs='--shorter|--longer|-lt|-le|-eq|-ne|-ge|-gt [+-]TIMESPAN'
getShortUsage()
{
    case "$1" in
	compare)
	    printf %s "$compareArgs";;
	*)  echo "ERROR: Unknown short usage topic \"$1\"!" >&2; return 2;;
    esac
}
getLongUsage()
{
    local topic="$1"; shift
    local description="$1"; shift
    local timespanFormat="$(durationToSeconds --get-short-usage format 2>/dev/null)"
    case "$topic" in
	compare)
	    cat <<HELPTEXT
    --shorter|--longer|-lt|-le|-eq|-ne|-ge|-gt ${timespanFormat:-TIMESPAN}
			${description:-Compare the timespan in the first column with TIMESPAN
			(purely mathematically).}
HELPTEXT
	    ;;
	*)  echo "ERROR: Unknown long usage topic \"$1\"!" >&2; return 2;;
    esac
}
printShortUsage()
{
    # Note: short followed by long option; if the user knows the short one, she can
    # skim the long one.
    printf 'Usage: cat FILE [...] | %q %s\n' "$(basename "$1")" "[-F|--field-separator FS] [-k|--keep-timespan] $compareArgs"
}
printUsage()
{
    # This is the short help when launched with no or incorrect arguments.
    # It is printed to stderr to avoid accidental processing.
    printShortUsage "$1" >&2
    printf >&2 '\nTry %q --help for more information.\n' "$(basename "$1")"
}
printLongUsage()
{
    # This is the long "man page" when launched with the help argument.
    # It is printed to stdout to allow paging with 'more'.
    cat <<HELPDESCRIPTION
Only print lines where the [+-]SECONDS timespan in the first column is longer /
shorter than [+-]TIMESPAN.
HELPDESCRIPTION
    echo
    printShortUsage "$1"
    echo
    cat <<HELPTEXT
    --field-separator|-F FS
			Use FS for splitting the data into columns (instead of
			the default whitespace). Unlike AWK, does not support a
			regular expression.
    --keep-timespan|-k	Keep the timespan column. By default, the column is
			dropped.
HELPTEXT
    getLongUsage compare
    cat <<HELPTEXT
EXIT STATUS:
    0	At least one timespan passed the comparison.
    1	No timespan passed the comparison.
    2	Bad invocation, wrong or missing command-line arguments.
    4	Some line(s) did not contain a valid timespan.
HELPTEXT
}

isKeepTimespan=
compareOp=
option() { :; }
parameter() { :; }
endOfOptionsAndParameters() { :; }
noUnderstand() { :; }
typeset -A understandsSubtopics=()
while [ $# -ne 0 ]
do
    case "$1" in
	--help|-h|-\?)	shift; printLongUsage "$0"; exit 0;;
	--get-short-usage)
			shift; getShortUsage "$@"; exit $?;;
	--get-long-usage)
			shift; getLongUsage "$@"; exit $?;;
	--understand-for)
			shift; understandsSubtopics["${1:?}"]=t; shift;;
	--understands)	shift
			option() { [ $# -eq 0 -a ${#understandsSubtopics[@]} -gt 0 -a ! "${understandsSubtopics["${1:-}"]}" ] && exit 1; printf 1; exit 0; }
			parameter() { [ $# -eq 0 -a ${#understandsSubtopics[@]} -gt 0 -a ! "${understandsSubtopics["${1:-}"]}" ] && exit 1; printf 2; exit 0; }
			endOfOptionsAndParameters() { exit 99; }
			noUnderstand() { exit 1; }
			;;

	--field-separator|-F)
			shift; IFS="$1"; shift; parameter;;
	--keep-timespan|-k)
			shift; isKeepTimespan=t; option;;
	--shorter)	shift; age=$(durationToSeconds -- "${1:?}") || { printf >&2 'ERROR: Illegal TIMESPAN: %s\n' "$1"; exit 2; }; shift; compareOp=-lt; parameter compare;;
	--longer)	shift; age=$(durationToSeconds -- "${1:?}") || { printf >&2 'ERROR: Illegal TIMESPAN: %s\n' "$1"; exit 2; }; shift; compareOp=-gt; parameter compare;;
	-lt|-le|-eq|-ne|-ge|-gt)
			compareOp="$1"; shift; age=$(durationToSeconds -- "${1:?}") || { printf >&2 'ERROR: Illegal TIMESPAN: %s\n' "$1"; exit 2; }; shift; parameter compare;;
	--)		endOfOptionsAndParameters; shift; break;;
	-*)		noUnderstand; { echo "ERROR: Unknown option \"$1\"!"; echo; printUsage "$0"; } >&2; exit 2;;
	*)		endOfOptionsAndParameters; break;;
    esac
done
if [ $# -ne 0 -o -z "$compareOp" ]; then
    printUsage "$0" >&2
    exit 2
fi

status=
isEOL=t
while read -r timespanField remainder || { isEOL=; [ -n "$line" ]; }
do
    if [[ "$timespanField" =~ ^[+-]?([0-9]+)$ ]]; then
	timespan="${BASH_REMATCH[1]}"
    else
	printf >&2 "ERROR: Not a timespan: '%s'.\\n" "$timespanField"
	status=4
	continue
    fi

    [ $timespan $compareOp $age ] || continue
    printf "%s${isEOL:+\\n}" "${isKeepTimespan:+${timespanField}${IFS:0:1}}$remainder"
    : ${status:=0}
done
exit ${status:-1}
