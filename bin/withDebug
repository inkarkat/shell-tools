#!/bin/bash
shopt -qs globstar extglob nullglob

: ${WITHDEBUG_COMMAND_JOINER=;}
: ${WITHDEBUG_EXEC_END=;}

readonly DATA_DIRSPEC="${XDG_DATA_HOME:-${HOME}/.local/share}"
readonly WITHDEBUG_RECALL_FILESPEC="${DATA_DIRSPEC}/withDebug"

printShortUsage()
{
    # Note: short followed by long option; if the user knows the short one, she can
    # skim the long one.
    printf 'Usage: %q %s\n' "$(basename "$1")" "[-p|--paginate|-i|--inbox] [-v|--verbose] [-m|--module MODULE|'' [-m ...]|-M|--only-module MODULE|'' [-M ...]] --for COMMANDNAME [--for ...] | -c|--command \"COMMANDLINE\" [...] | --exec SIMPLECOMMAND [...] ${WITHDEBUG_EXEC_END} [--exec ...] | [--] SIMPLECOMMAND [...] [-?|-h|--help]"
    echo
    printf 'Usage: %q %s\n' "$(basename "$1")" "--recall [-p|--paginate|-i|--inbox] [-v|--verbose] [-m|--module MODULE|'' [-m ...]|-M|--only-module MODULE|'' [-M ...]] --for COMMANDNAME [--for ...]"
}
printUsage()
{
    # This is the short help when launched with no or incorrect arguments.
    # It is printed to stderr to avoid accidental processing.
    printShortUsage "$1" >&2
    printf >&2 '\nTry %q --help for more information.\n' "$(basename "$1")"
}
printLongUsage()
{
    # This is the long "man page" when launched with the help argument.
    # It is printed to stdout to allow paging with 'more'.
    cat <<HELPDESCRIPTION
Execute COMMAND while enabling debugging diagnostics for it. This is done by
adding the COMMAND's name to the \$DEBUG environment variable.
If DEBUG_<command-name>[_<module>]_WRAPPER (<module> without any trailing
sigil(s)) environment variables exist, their contents are prepended before the
corresponding COMMAND and that executed instead.
HELPDESCRIPTION
    echo
    printShortUsage "$1"
    echo
    cat <<HELPTEXT
    --paginate|-p	Show the debugging diagnostics (and all other stderr
			output) separately after the execution.
    --inbox|-i		Write the debugging diagnostics into the inbox.
    --verbose|-v	Print the full command line (with all debugging
			configuration) before executing it, in a format suitable
			for copy-and-pasting it into the shell.
    --module|-m MODULE	Also enable debugging diagnostics for MODULE of the
			following COMMAND(s).
    --only-module|-M MODULE
			Just enable debugging diagnostics for MODULE of the
			following COMMAND(s), but not for the overall COMMAND
			itself.
    --[only-]module ''	Reset modules; following COMMAND(s) just print the
			overall debugging diagnostics.
    --for COMMANDNAME	Also enable debugging diagnostics and wrapper commands
			for COMMANDNAME.
    --command|-c CMD	Execute CMD as a command-line.
    --exec CMD [...] ${WITHDEBUG_EXEC_END}	Execute CMD; all following arguments are taken to be
			arguments to the CMD until an argument consisting of
			'${WITHDEBUG_EXEC_END}' is encountered.
    --recall		Rerun the previous debugging command, optionally
			dropping matching arguments or adding those not given to
			the original command.
HELPTEXT
}

isOnly=
typeset -a modules=('')
addModule()
{
    [ -n "$1" ] && modules+=("$1")
}

add()
{
    DEBUG+="${DEBUG:+,}${1:?}"
}
typeset -a commandNames=()
addDebug()
{
    commandName="${1:?}"; shift
    commandNames+=("$commandName")

    local module; for module in "${modules[@]}"
    do
	add "${commandName}${module:+:}${module}"
    done
}
addDebugCommand()
{
    local cmd="${1:?}"; shift
    commandName="$(commandName --no-interpreter --eval "$cmd")"
    if [ -z "$commandName" ]; then
	printf >&2 'ERROR: Could not determine command name for %s\n' "$cmd"
	return 1
    fi
    addDebug "$commandName"
}

addCommand()
{
    local cmd="${1:?}"; shift

    local wrappers='' commandName
    for commandName in "${commandNames[@]}"
    do
	local module; for module in "${modules[@]}"
	do
	    module="${module%%+([^[:alnum:]])}"
	    local wrapperConfigName="DEBUG_${commandName//[^[:alnum:]]/_}${module:+_}${module//[^[:alnum:]]/_}_WRAPPER"
	    if [ -n "${!wrapperConfigName}" ]; then
		# Prepend the wrapper command to the executed command.
		wrappers+="${!wrapperConfigName} "
	    fi
	done
    done

    commands+="${commands:+ $WITHDEBUG_COMMAND_JOINER }${wrappers}${cmd}"
}

handleRecall()
{
    if [ ! -r "$WITHDEBUG_RECALL_FILESPEC" ]; then
	echo >&2 'ERROR: No previous debug command to retry.'
	exit 1
    fi

    local overrideVerbose=
    local overridePaginate=
    local overrideInbox=
    typeset -A overrideFor=()
    typeset -A overrideModules=()
    typeset -A overrideOnlyModules=()
    while [ $# -ne 0 ]
    do
	case "$1" in
	    --verbose|-v)	shift; overrideVerbose=t;;
	    --paginate|-p)	shift; overridePaginate=t;;
	    --inbox|-i)		shift; overrideInbox=t;;
	    --for)		shift; overrideFor["$1"]=t; shift;;
	    --module|-m)	shift; overrideModules["$1"]=t; shift;;
	    --only-module|-M)	shift; overrideOnlyModules["$1"]=t; shift;;
	    --)			shift; break;;
	    *)			shift;;
	esac
    done

    source "$WITHDEBUG_RECALL_FILESPEC" || exit 3

    # Iterate over the previously given arguments to remove those also given to the
    # recall.
    allargs=()	# These will be returned.
    while [ $# -ne 0 ]
    do
	case "$1" in
	    --verbose|-v)	[ "$overrideVerbose" ] && overrideVerbose= || allargs+=("$1"); shift;;
	    --paginate|-p)	[ "$overridePaginate" ] && overridePaginate= || allargs+=("$1"); shift;;
	    --inbox|-i)		[ "$overrideInbox" ] && overrideInbox= || allargs+=("$1"); shift;;
	    --for)		[ "${overrideFor["$2"]}" ] && unset "overrideFor[$2]" || allargs+=("$1" "$2"); shift; shift;;
	    --module|-m)	[ "${overrideModules["$2"]}" ] && unset "overrideModules[$2]" || allargs+=("$1" "$2"); shift; shift;;
	    --only-module|-M)   [ "${overrideOnlyModules["$2"]}" ] && unset "overrideOnlyModules[$2]" || allargs+=("$1" "$2"); shift; shift;;
	    --)			allargs+=("$@"); break;;
	    *)			allargs+=("$1"); shift;;
	esac
    done

    # Add those arguments given to the recall that were not used to remove any
    # recalled arguments.
    typeset -a newArgs=()
    [ "$overrideVerbose" ] && newArgs+=(--verbose)
    [ "$overridePaginate" ] && newArgs+=(--paginate)
    [ "$overrideInbox" ] && newArgs+=(--inbox)
    local arg
    for arg in "${!overrideFor[@]}"
    do
	newArgs+=(--for "$arg")
    done
    for arg in "${!overrideModules[@]}"
    do
	newArgs+=(--module "$arg")
    done
    for arg in "${!overrideOnlyModules[@]}"
    do
	newArgs+=(--only-module "$arg")
    done

    # Return via allargs array.
    allargs=("${newArgs[@]}" "${allargs[@]}")
}

saveToInbox()
{
    inbox --base "${commandNames[0]:?}" -- "$@"
}

typeset -a allargs=("$@")
isVerbose=
commands=
let commandCnt=0
typeset -a viewer=()
while [ $# -ne 0 ]
do
    case "$1" in
	--help|-h|-\?)	shift; printLongUsage "$0"; exit 0;;
	--recall)	shift; handleRecall "$@"; set -- "${allargs[@]}";;
	--paginate|-p)	shift
			[ "$PAGER" = smartless ] && PAGER=less	# smartless does not page small outputs that fit the terminal, but we explicitly want to page through the captured debug diagnostics.
			viewer=("${PAGER:-less}" --RAW-CONTROL-CHARS --)
			;;
	--inbox|-i)	shift; viewer=(saveToInbox);;
	--verbose|-v)	shift; isVerbose=t;;
	--for)		shift
			addDebug "${1:?}"; shift
			;;
	--module|-m)	shift
			[ "$isOnly" ] && modules=('')
			isOnly=
			addModule "${1?}"; shift
			;;
	--only-module|-M)
			shift
			[ "$isOnly" ] || modules=()
			isOnly=t
			addModule "${1?}"; shift
			;;
	--command|-c)	shift
			addDebugCommand "${1:?}" || exit 2
			addCommand "$1"
			if [[ "$1" =~ [\;\&\|] ]]; then
			    let commandCnt+=2	# multiple commands
			else
			    let commandCnt+=1
			fi
			shift
			;;
	--exec)		shift
			cmd=
			while [ $# -gt 0 -a "$1" != "$WITHDEBUG_EXEC_END" ]
			do
			    printf -v quotedArg '%q' "$1"
			    cmd+="${cmd:+ }${quotedArg}"
			    shift
			done
			if [ $# -eq 0 ]; then
			    echo "ERROR: --exec command must be concluded with '${WITHDEBUG_EXEC_END}'"; echo; printUsage "$0"
			    exit 2
			fi >&2
			shift
			addDebugCommand "$cmd" || exit 2
			addCommand "$cmd"
			let commandCnt+=1
			;;
	--)		shift; break;;
	-*)		{ echo "ERROR: Unknown option \"$1\"!"; echo; printUsage "$0"; } >&2; exit 2;;
	*)		break;;
    esac
done
if [ $# -ne 0 ]; then
    # Combine --command and SIMPLECOMMAND; need to quote SIMPLECOMMAND to
    # undo the effects of eval.
    printf -v quotedSimpleCommand '%q ' "$@"
    quotedSimpleCommand="${quotedSimpleCommand% }"
    addDebugCommand "$quotedSimpleCommand" || exit 2
    addCommand "$quotedSimpleCommand"
    let commandCnt+=1
fi
if [ -z "$commands" ]; then
    echo "ERROR: No COMMAND(s) specified; need to pass -c|--command \"COMMANDLINE\", or --exec SIMPLECOMMAND [...] $WITHDEBUG_EXEC_END or SIMPLECOMMAND."
    echo
    printUsage "$0"
    exit 2
fi >&2

printf -v quotedArgs ' %q' "${allargs[@]}"
printf 'set --%s\n' "$quotedArgs" > "$WITHDEBUG_RECALL_FILESPEC"

if [ "$isVerbose" ]; then
    if [ $commandCnt -eq 1 ]; then
	printf >&2 '%sDEBUG=%q %s\n' "${PS4:-\$ }" "$DEBUG" "$commands"
    else
	printf >&2 '%s{ DEBUG=%q; %s; }\n' "${PS4:-\$ }" "$DEBUG" "$commands"
    fi
fi

export DEBUG

eval "${viewer:+{ }${commands}${viewer:+;\} 3>&1 1>&2 2>&3 3>&- }" \
    "${viewer:+|}" '"${viewer[@]}"' "${viewer:+ 3>&1 1>&2 2>&3 3>&-}"
